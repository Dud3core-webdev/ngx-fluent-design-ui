/* To learn more about this file see: https://angular.dev/config/tsconfig. */
{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "outDir": "./out-tsc/spec",
        "types": [
            "jest",
            "node"
        ],
        "esModuleInterop": true,
        "module": "Node16",
        "moduleResolution": "Node16",
        "isolatedModules": true
    },
    "include": [
        "src/**/*.spec.ts",
        "src/**/*.d.ts",
        "projects/**/*.spec.ts",
        "projects/**/*.d.ts"
    ]
}